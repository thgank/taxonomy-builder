{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "incremental": false,
    "plugins": []
  },
  "include": [
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx",
    "src/entities/**/*.ts",
    "src/features/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
