      "targets": [
        {
          "alias": "Browse > 1500ms",
          "datasource": {
            "type": "influxdb",
            "uid": "taxonomy-k6-influxdb"
          },
          "query": "SELECT count(\"p95\") FROM (SELECT percentile(\"value\", 95) AS \"p95\" FROM \"http_req_duration\" WHERE $timeFilter AND \"env\" =~ /^$env$/ AND \"script\" = 'collections-browse-load' GROUP BY time(1h)) WHERE \"p95\" > 1500",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "alias": "Status > 1200ms",
          "datasource": {
            "type": "influxdb",
            "uid": "taxonomy-k6-influxdb"
          },
          "query": "SELECT count(\"p95\") FROM (SELECT percentile(\"value\", 95) AS \"p95\" FROM \"http_req_duration\" WHERE $timeFilter AND \"env\" =~ /^$env$/ AND \"script\" = 'job-status-load' GROUP BY time(1h)) WHERE \"p95\" > 1200",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        },
        {
          "alias": "Burst > 2000ms",
          "datasource": {
            "type": "influxdb",
            "uid": "taxonomy-k6-influxdb"
          },
          "query": "SELECT count(\"p95\") FROM (SELECT percentile(\"value\", 95) AS \"p95\" FROM \"http_req_duration\" WHERE $timeFilter AND \"env\" =~ /^$env$/ AND \"script\" = 'job-create-burst' GROUP BY time(1h)) WHERE \"p95\" > 2000",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        },
        {
          "alias": "Mixed > 2000ms",
          "datasource": {
            "type": "influxdb",
            "uid": "taxonomy-k6-influxdb"
          },
          "query": "SELECT count(\"p95\") FROM (SELECT percentile(\"value\", 95) AS \"p95\" FROM \"http_req_duration\" WHERE $timeFilter AND \"env\" =~ /^$env$/ AND \"script\" = 'mixed-workflow-load' GROUP BY time(1h)) WHERE \"p95\" > 2000",
          "rawQuery": true,
          "refId": "D",
          "resultFormat": "time_series"
        }
      ],
      "title": "Hourly SLA Breaches In Range",
      "type": "bargauge"
