{
  "info": {
    "_postman_id": "8d101773-b145-4a3e-9d22-0b380b2d3c0a",
    "name": "Taxonomy Builder QA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Starter collection for smoke and regression checks against the Taxonomy Builder API."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "apiKey",
      "value": "dev-api-key-change-me"
    },
    {
      "key": "collectionId",
      "value": ""
    },
    {
      "key": "jobId",
      "value": ""
    },
    {
      "key": "taxonomyId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Collections",
      "item": [
        {
          "name": "Create Collection",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('collectionId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"QA Collection {{$timestamp}}\",\n  \"description\": \"Created from Postman smoke collection\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/collections",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections"
              ]
            }
          }
        },
        {
          "name": "List Collections",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/collections",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections"
              ]
            }
          }
        },
        {
          "name": "Get Collection",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/collections/{{collectionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections",
                "{{collectionId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "Upload Documents",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/collections/{{collectionId}}/documents:upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections",
                "{{collectionId}}",
                "documents:upload"
              ]
            },
            "description": "Attach one or more local files before running the request."
          }
        },
        {
          "name": "List Collection Documents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/collections/{{collectionId}}/documents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections",
                "{{collectionId}}",
                "documents"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Create Full Pipeline Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('jobId', json.id);",
                  "}",
                  "if (json.taxonomyVersionId) {",
                  "  pm.collectionVariables.set('taxonomyId', json.taxonomyVersionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"FULL_PIPELINE\",\n  \"params\": {\n    \"method_term_extraction\": \"both\",\n    \"method_taxonomy\": \"hybrid\",\n    \"max_terms\": 100,\n    \"min_freq\": 1,\n    \"similarity_threshold\": 0.55,\n    \"chunk_size\": 1000,\n    \"max_depth\": 6\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/collections/{{collectionId}}/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections",
                "{{collectionId}}",
                "jobs"
              ]
            }
          }
        },
        {
          "name": "Get Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs",
                "{{jobId}}"
              ]
            }
          }
        },
        {
          "name": "Get Job Events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/jobs/{{jobId}}/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs",
                "{{jobId}}",
                "events"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Taxonomies",
      "item": [
        {
          "name": "List Collection Taxonomies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/collections/{{collectionId}}/taxonomies",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "collections",
                "{{collectionId}}",
                "taxonomies"
              ]
            }
          }
        },
        {
          "name": "Get Taxonomy Tree",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/taxonomies/{{taxonomyId}}/tree",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "taxonomies",
                "{{taxonomyId}}",
                "tree"
              ]
            }
          }
        },
        {
          "name": "Search Concepts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/taxonomies/{{taxonomyId}}/concepts/search?q=bank",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "taxonomies",
                "{{taxonomyId}}",
                "concepts",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "bank"
                }
              ]
            }
          }
        },
        {
          "name": "Export Taxonomy JSON",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/taxonomies/{{taxonomyId}}/export?format=json",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "taxonomies",
                "{{taxonomyId}}",
                "export"
              ],
              "query": [
                {
                  "key": "format",
                  "value": "json"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
