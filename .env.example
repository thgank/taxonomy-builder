# ── Postgres ──────────────────────────────────────────────
POSTGRES_PASSWORD=taxonomy_secret

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_PASSWORD=rabbit_secret

# ── API Service ───────────────────────────────────────────
API_KEY=dev-api-key-change-me

# ── Worker Service ────────────────────────────────────────
LOG_LEVEL=INFO
SPACY_MODEL_EN=en_core_web_sm
SPACY_MODEL_RU=ru_core_news_sm
SPACY_MODEL_KK=
SUPPORTED_LANGUAGES=en,ru,kk
DEFAULT_LANGUAGE=en
MIN_DOC_FREQ=2
MIN_TERM_QUALITY_SCORE=0.40

# ── Taxonomy Builder Knobs (domain-agnostic) ─────────────
PARENT_POOL_SIZE=5
MAX_CHILDREN_PER_PARENT=6
ADAPTIVE_PERCENTILE=45

# ── Quality Gate Thresholds ───────────────────────────────
QUALITY_MIN_EDGE_DENSITY=0.20
QUALITY_MIN_LARGEST_COMPONENT_RATIO=0.40
QUALITY_MAX_HUBNESS=6.0
QUALITY_MAX_LEXICAL_NOISE_RATE=0.05

# ── Optional: Safe Orphan Linking ────────────────────────
ORPHAN_LINKING_ENABLED=true
ORPHAN_LINK_THRESHOLD=0.57
ORPHAN_LINK_MAX_LINKS=30
COMPONENT_BRIDGING_ENABLED=true
COMPONENT_BRIDGE_THRESHOLD=0.54
COMPONENT_BRIDGE_MAX_LINKS=20
MIN_PARENT_DOC_FREQ=3
