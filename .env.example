# ── Postgres ──────────────────────────────────────────────
POSTGRES_PASSWORD=taxonomy_secret

# ── RabbitMQ ──────────────────────────────────────────────
RABBITMQ_PASSWORD=rabbit_secret

# ── API Service ───────────────────────────────────────────
API_KEY=dev-api-key-change-me

# ── Worker Service ────────────────────────────────────────
LOG_LEVEL=INFO
SPACY_MODEL_EN=en_core_web_sm
SPACY_MODEL_RU=ru_core_news_sm
SPACY_MODEL_KK=
SUPPORTED_LANGUAGES=en,ru,kk
DEFAULT_LANGUAGE=en
MIN_DOC_FREQ=2
MIN_TERM_QUALITY_SCORE=0.40
CHUNK_MIN_CHARS=80
MAX_OCCURRENCES_PER_TERM=80

# ── Taxonomy Builder Knobs (domain-agnostic) ─────────────
PARENT_POOL_SIZE=5
MAX_CHILDREN_PER_PARENT=6
ADAPTIVE_PERCENTILE=45

# ── Quality Gate Thresholds ───────────────────────────────
QUALITY_MIN_EDGE_DENSITY=0.20
QUALITY_MIN_LARGEST_COMPONENT_RATIO=0.40
QUALITY_MAX_HUBNESS=6.0
QUALITY_MAX_LEXICAL_NOISE_RATE=0.05

# ── Optional: Safe Orphan Linking ────────────────────────
ORPHAN_LINKING_ENABLED=true
ORPHAN_LINK_THRESHOLD=0.57
ORPHAN_LINK_MAX_LINKS=30
COMPONENT_BRIDGING_ENABLED=true
COMPONENT_BRIDGE_THRESHOLD=0.54
COMPONENT_BRIDGE_MAX_LINKS=20
MIN_PARENT_DOC_FREQ=3

# ── Active Learning / Ranker / Evidence ────────────────
ADAPTIVE_THRESHOLDS_ENABLED=true
THRESHOLD_PROFILE_NAME=default
THRESHOLD_PROFILE_GLOBAL_FALLBACK=true
ACTIVE_LEARNING_ENABLED=true
ACTIVE_LEARNING_BATCH_SIZE=200
ACTIVE_LEARNING_MIN_RISK_SCORE=0.35
THRESHOLD_MAX_UPDATE_STEP=0.03
THRESHOLD_MIN_LABEL_SAMPLES=50

EDGE_RANKER_ENABLED=false
EDGE_RANKER_MODEL_PATH=./data/models/edge_ranker.joblib
EDGE_RANKER_BLEND_ALPHA=0.45
EDGE_RANKER_MIN_CONFIDENCE=0.40

EVIDENCE_LINKING_ENABLED=false
EVIDENCE_TOP_K=5
EVIDENCE_WINDOW_CHARS=220
EVIDENCE_MAX_PAIRS_PER_JOB=200

# ── Multilingual Quality Gates ─────────────────────────
PER_LANG_MIN_COVERAGE=0.45
CROSS_LANG_CONSISTENCY_MIN=0.80
